# Local development environment variables
# Copy to .env and fill in values.
# Do NOT commit .env — it is git-ignored.

# ===============================
# Project Identity (set this first)
# ===============================
# APP_NAME is used as the default DB name, Docker Compose defaults, and scripts.
# Set it once here — docker-compose and scripts pick it up automatically.
APP_NAME=my-app

# ===============================
# Application
# ===============================
SERVER_PORT=8080
SPRING_APPLICATION_NAME=my-app
SPRING_PROFILES_ACTIVE=local

# ===============================
# Database (PostgreSQL)
# ===============================
# POSTGRES_DB and POSTGRES_USER default to APP_NAME in docker-compose.
# Only override these if you need a different DB or user name.
# POSTGRES_DB=my-app
# POSTGRES_USER=my-app
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Update the values below to match your APP_NAME.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/my-app
SPRING_DATASOURCE_USERNAME=my-app
SPRING_DATASOURCE_PASSWORD=changeme

# ===============================
# JPA / Hibernate
# ===============================
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# ===============================
# Flyway
# ===============================
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_LOCATIONS=classpath:db/migration

# ===============================
# External API (Phase 2+)
# ===============================
# TODO: Replace with your external API env vars.
# EXTERNAL_API_BASE_URL=https://api.example.com/v1
# EXTERNAL_API_TIMEOUT_MS=5000

# ===============================
# Testcontainers (Tests only)
# ===============================
TEST_DATASOURCE_IMAGE=postgres:16-alpine
TEST_DATASOURCE_DB=my-app_test
TEST_DATASOURCE_USER=test
TEST_DATASOURCE_PASSWORD=test

# ===============================
# Actuator
# ===============================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info

# ===============================
# Ping Endpoint
# ===============================
PING_PATH=/ping
